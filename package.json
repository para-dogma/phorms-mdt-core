{
  "name": "phorms-mdt-core",
  "version": "1.0.0",
  "description": "Core engine for Multidimensional Tokens (MDT) on TON. Implements hard-split logic, 5-vector Merkle roots, and time-lock consensus for RWA.",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tact build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [
    "ton",
    "blockchain",
    "tact",
    "multidimensional-tokens",
    "mdt",
    "rwa",
    "hard-split",
    "merkle-roots",
    "time-lock"
  ],
  "author": "PhormS Team",
  "license": "MIT",
  "dependencies": {
    "@ton/core": "^0.48.0",
    "@ton/crypto": "^0.48.0"
  },
  "devDependencies": {
    "@ton/sandbox": "^0.14.0",
    "@ton/test-utils": "^0.14.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
